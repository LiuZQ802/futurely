{
  "name": "desktop-list",
  "version": "1.0.0",
  "description": "桌面任务清单",
  "main": "electron/main.js",
  "scripts": {
    "dev": "concurrently -k \"vite\" \"electron .\"",
    "build": "vite build",
    "electron": "electron .",
    "pack": "vite build && electron-builder"
  },
  "dependencies": {
    "pinia": "^2.1.7",
    "uuid": "^9.0.1",
    "vue": "^3.4.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.0.0",
    "concurrently": "^8.2.2",
    "wait-on": "^7.2.0",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "vite": "^5.0.0",
    "vite-plugin-electron": "^0.28.0"
  },
  "build": {
    "appId": "com.desktoplist.app",
    "productName": "桌面清单",
    "directories": {
      "output": "release"
    },
    "win": {
      "target": "nsis",
      "icon": "public/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "runAfterFinish": true
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "node_modules/**/*"
    ]
  }
}
